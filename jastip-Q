<!DOCTYPE html>

<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jastip-Q — Katalog Korea</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Pacifico&family=DM+Sans:wght@300;400;500;600&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#FBF8F4; --surface:#fff; --coral:#E85D4A; --coral-dk:#C94A38;
  --coral-lt:#FFF0EE; --text:#1A1A1A; --muted:#6B6B6B; --border:#EDE8E3;
  --radius:16px; --shadow:0 4px 24px rgba(0,0,0,.07);
  --green:#25D366;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Nunito',sans-serif;background:var(--bg);color:var(--text);padding-bottom:110px}

/* HERO */
.hero{background:linear-gradient(135deg,#1A1A1A,#2D1F1C 60%,#4A2820);color:#fff;padding:44px 24px 36px;text-align:center;position:relative;overflow:hidden}
.hero::before{content:’’;position:absolute;top:-40px;right:-40px;width:200px;height:200px;background:radial-gradient(circle,rgba(232,93,74,.3),transparent 70%);border-radius:50%}
.hero::after{content:’’;position:absolute;bottom:-60px;left:-30px;width:160px;height:160px;background:radial-gradient(circle,rgba(232,93,74,.2),transparent 70%);border-radius:50%}
.hero-tag{display:inline-block;background:var(–coral);color:#fff;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;padding:6px 16px;border-radius:20px;margin-bottom:14px;font-family:‘Nunito’,sans-serif}
.hero h1{font-family:‘Pacifico’,cursive;font-size:clamp(38px,10vw,64px);line-height:1.1;margin-bottom:6px;text-shadow:3px 3px 0 rgba(232,93,74,.4)}
.hero h1 span{color:var(–coral)}
.hero-sub{font-size:14px;color:rgba(255,255,255,.65);margin-bottom:20px;font-weight:400}
.hero-info{display:flex;gap:8px;justify-content:center;flex-wrap:wrap}
.hero-chip{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);color:rgba(255,255,255,.85);font-size:12px;padding:5px 14px;border-radius:20px;font-family:‘Nunito’,sans-serif}

/* KURS TICKER */
.kurs-bar{background:#1A1A1A;color:rgba(255,255,255,.8);padding:9px 20px;text-align:center;font-size:12px;font-family:‘Nunito’,sans-serif;border-bottom:1px solid #333}
.kurs-bar strong{color:#FFD700;font-weight:800}
.kurs-bar span{color:rgba(255,255,255,.5);margin:0 8px}

/* ONGKIR */
.ongkir-banner{background:var(–coral-lt);border-bottom:1px solid #F5C8C3;padding:10px 20px;text-align:center;font-size:12px;color:var(–coral-dk);font-weight:700}
.ongkir-banner span{font-weight:400;margin:0 4px}

/* INFO BOXES */
.info-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:12px 14px 4px}
.info-box{background:#fff;border-radius:12px;padding:12px;text-align:center;box-shadow:var(–shadow)}
.info-box .icon{font-size:20px;margin-bottom:4px}
.info-box .label{font-size:10px;color:var(–muted);font-weight:600;text-transform:uppercase;letter-spacing:.5px}
.info-box .value{font-size:13px;font-weight:800;color:var(–text);margin-top:2px}
.info-box.highlight{background:var(–coral-lt);border:1px solid #F5C8C3}
.info-box.highlight .value{color:var(–coral-dk)}

/* STICKY FILTER */
.sticky-filter{position:sticky;top:0;z-index:100;background:#fff;border-bottom:1px solid var(–border);box-shadow:0 2px 12px rgba(0,0,0,.08)}
.sel-banner{display:none;background:#1A1A1A;color:#fff;padding:9px 16px;font-size:13px;font-weight:600;align-items:center;justify-content:space-between;gap:10px}
.sel-banner.on{display:flex}
.sel-banner strong{color:var(–coral)}
.btn-cancel{background:none;border:1px solid rgba(255,255,255,.3);color:#fff;font-family:‘Nunito’,sans-serif;font-size:12px;padding:5px 12px;border-radius:12px;cursor:pointer}
.filter-scroll{overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;padding:10px 14px}
.filter-scroll::-webkit-scrollbar{display:none}
.filters{display:flex;gap:8px;width:max-content}
.filter-btn{border:1.5px solid var(–border);background:transparent;color:var(–muted);font-family:‘Nunito’,sans-serif;font-size:13px;font-weight:700;padding:7px 16px;border-radius:24px;cursor:pointer;transition:all .2s;white-space:nowrap}
.filter-btn:hover{border-color:var(–coral);color:var(–coral)}
.filter-btn.active{background:var(–coral);border-color:var(–coral);color:#fff}

/* COUNT */
.section-header{padding:10px 18px 4px;display:flex;align-items:center;justify-content:space-between}
.section-count{font-size:13px;color:var(–muted);font-weight:600}
.hint{font-size:11px;color:var(–muted)}

/* GRID */
.grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;padding:10px 12px 24px}
@media(min-width:540px){.grid{grid-template-columns:repeat(3,1fr)}}
@media(min-width:780px){.grid{grid-template-columns:repeat(4,1fr)}}

/* CARD */
.card{background:#fff;border-radius:var(–radius);overflow:hidden;box-shadow:var(–shadow);transition:transform .2s,box-shadow .2s,outline .15s;position:relative;animation:fadeUp .35s ease both}
.card:hover{transform:translateY(-3px);box-shadow:0 8px 28px rgba(0,0,0,.11)}
.card.selected{outline:2.5px solid var(–coral);transform:translateY(-2px)}
.card.hidden{display:none!important}
@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}

.selected-badge{position:absolute;top:8px;right:8px;z-index:10;width:26px;height:26px;background:var(–coral);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;opacity:0;transform:scale(.6);transition:all .2s;pointer-events:none}
.card.selected .selected-badge{opacity:1;transform:scale(1)}

.card-img{position:relative;aspect-ratio:1/1;overflow:hidden;background:#f5f5f5}
.card-img img{width:100%;height:100%;object-fit:cover;transition:transform .4s}
.card:hover .card-img img{transform:scale(1.04)}
.cat-badge{position:absolute;top:8px;left:8px;background:rgba(0,0,0,.55);color:#fff;font-size:14px;padding:3px 8px;border-radius:10px;backdrop-filter:blur(4px);pointer-events:none}

.card-body{padding:11px}
.card-cat{font-size:10px;font-weight:800;letter-spacing:.5px;text-transform:uppercase;color:var(–coral);margin-bottom:2px}
.card-name{font-size:13px;font-weight:800;line-height:1.3;margin-bottom:2px}
.card-variant{font-size:11px;color:var(–muted);margin-bottom:4px;font-weight:600}
.card-desc{font-size:11px;color:var(–muted);line-height:1.4;margin-bottom:7px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}

/* CONTROLS */
.card-controls{display:flex;align-items:center;gap:7px;margin-bottom:9px;flex-wrap:wrap}
.size-wrap{flex:1;min-width:0}
.size-select{width:100%;border:1.5px solid var(–border);border-radius:10px;padding:6px 8px;font-family:‘Nunito’,sans-serif;font-size:12px;font-weight:600;color:var(–text);background:#fff;outline:none;cursor:pointer;transition:border-color .2s}
.size-select:focus{border-color:var(–coral)}
.size-single{font-size:11px;color:var(–muted);padding:4px 0;font-weight:600}
.qty-wrap{display:flex;align-items:center;gap:3px;flex-shrink:0}
.qty-btn{width:25px;height:25px;border:1.5px solid var(–border);background:#fff;border-radius:8px;font-size:14px;font-weight:800;cursor:pointer;color:var(–text);line-height:1;transition:all .15s;display:flex;align-items:center;justify-content:center}
.qty-btn:hover{border-color:var(–coral);color:var(–coral)}
.qty-val{font-size:13px;font-weight:800;min-width:18px;text-align:center}

.card-footer{display:flex;align-items:center;justify-content:space-between;gap:6px}
.price{font-size:14px;font-weight:800;color:var(–coral-dk);display:block}
.price-won{font-size:10px;color:var(–muted);font-weight:600}
.btn-add{background:var(–coral);color:#fff;border:none;font-family:‘Nunito’,sans-serif;font-size:11px;font-weight:800;padding:7px 11px;border-radius:10px;cursor:pointer;white-space:nowrap;transition:background .2s}
.btn-add:hover{background:var(–coral-dk)}
.card.selected .btn-add{background:#1A1A1A}

/* DISCOUNT SECTION */
.discount-section{margin:12px 14px 0;background:#fff;border-radius:var(–radius);padding:14px;box-shadow:var(–shadow);border:1.5px dashed var(–coral)}
.discount-title{font-size:13px;font-weight:800;color:var(–coral-dk);margin-bottom:8px}
.discount-input{width:100%;border:1.5px solid var(–border);border-radius:10px;padding:9px 12px;font-family:‘Nunito’,sans-serif;font-size:13px;font-weight:600;color:var(–text);outline:none;transition:border-color .2s}
.discount-input:focus{border-color:var(–coral)}
.discount-hint{font-size:11px;color:var(–muted);margin-top:5px}

/* ORDER BAR */
.order-bar{position:fixed;bottom:0;left:0;right:0;background:#1A1A1A;padding:12px 18px;display:none;align-items:center;justify-content:space-between;gap:10px;z-index:200;box-shadow:0 -4px 24px rgba(0,0,0,.25);animation:slideUp .25s ease}
.order-bar.on{display:flex}
@keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
.bar-info{flex:1}
.bar-count{font-size:11px;color:rgba(255,255,255,.6);font-weight:600}
.bar-total{font-size:16px;font-weight:800;color:#fff}
.bar-total small{font-size:11px;font-weight:400;color:rgba(255,255,255,.5)}
.btn-chat{display:inline-flex;align-items:center;gap:7px;background:var(–green);color:#fff;border:none;font-family:‘Nunito’,sans-serif;font-size:13px;font-weight:800;padding:11px 18px;border-radius:14px;cursor:pointer;white-space:nowrap;transition:opacity .2s}
.btn-chat:hover{opacity:.9}
.btn-clear{background:none;border:1px solid rgba(255,255,255,.2);color:rgba(255,255,255,.6);font-family:‘Nunito’,sans-serif;font-size:12px;padding:7px 10px;border-radius:10px;cursor:pointer}

/* FOOTER */
footer{background:#1A1A1A;color:rgba(255,255,255,.6);text-align:center;padding:28px 20px;font-size:12px;line-height:1.8;font-family:‘Nunito’,sans-serif}
.footer-brand{font-family:‘Pacifico’,cursive;font-size:22px;color:var(–coral);margin-bottom:8px}
.footer-wa{display:inline-flex;align-items:center;gap:8px;background:var(–green);color:#fff;padding:12px 24px;border-radius:28px;font-size:14px;font-weight:800;text-decoration:none;margin:12px 0}
.no-results{grid-column:1/-1;text-align:center;padding:48px 20px;color:var(–muted);display:none}

/* MISSING NOTICE */
.missing-notice{margin:8px 14px;background:#FFF9E6;border:1.5px solid #FFD700;border-radius:12px;padding:10px 14px;font-size:12px;color:#7A5F00;font-weight:600}
</style>

</head>
