<script>
const cart = new Map();

function doFilter(cat, btn) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  let vis = 0;
  document.querySelectorAll('.card').forEach(c => {
    const show = cat === 'all' || c.dataset.cat === cat;
    c.classList.toggle('hidden', !show);
    if (show) vis++;
  });
  document.getElementById('count').textContent = 'Menampilkan ' + vis + ' produk';
  document.getElementById('noResults').style.display = vis === 0 ? 'block' : 'none';
}

function changeQty(btn, delta) {
  const wrap = btn.closest('.qty-wrap');
  const valEl = wrap.querySelector('.qty-val');
  let v = parseInt(valEl.textContent) + delta;
  if (v < 1) v = 1;
  if (v > 99) v = 99;
  valEl.textContent = v;
  const card = btn.closest('.card');
  if (card.classList.contains('selected')) {
    const id = card.dataset.id;
    if (cart.has(id)) { cart.get(id).qty = v; updateBar(); }
  }
}

function addToOrder(btn) {
  const card = btn.closest('.card');
  const id = card.dataset.id;
  if (card.classList.contains('selected')) {
    cart.delete(id);
    card.classList.remove('selected');
    btn.textContent = '+ Pilih';
    updateBar();
    return;
  }
  const sizeEl = card.querySelector('.size-select');
  let size;
  if (sizeEl && sizeEl.tagName === 'SELECT') {
    if (!sizeEl.value) {
      sizeEl.style.borderColor = '#E85D4A';
      sizeEl.focus();
      setTimeout(() => sizeEl.style.borderColor = '', 1500);
      return;
    }
    size = sizeEl.value;
  } else {
    size = card.querySelector('input[type=hidden]')?.value || '-';
  }
  const qty = parseInt(card.querySelector('.qty-val').textContent);
  cart.set(id, {
    name: card.dataset.name,
    variant: card.dataset.variant,
    size, qty,
    unitPrice: parseInt(card.dataset.price),
    priceFmt: card.dataset.priceFmt,
    won: card.dataset.won,
  });
  card.classList.add('selected');
  btn.textContent = '✓ Dipilih';
  updateBar();
}

function updateBar() {
  const totalQty = [...cart.values()].reduce((s,i) => s+i.qty, 0);
  const totalIdr = [...cart.values()].reduce((s,i) => s+i.unitPrice*i.qty, 0);
  const totalFmt = 'Rp ' + totalIdr.toLocaleString('id-ID');
  document.getElementById('selCount').textContent = cart.size;
  document.getElementById('barCount').textContent = totalQty + ' item (' + cart.size + ' produk)';
  document.getElementById('barTotal').innerHTML = totalFmt + ' <small>(belum ongkir)</small>';
  const on = cart.size > 0;
  document.getElementById('orderBar').classList.toggle('on', on);
  document.getElementById('selBanner').classList.toggle('on', on);
}

function clearAll() {
  cart.clear();
  document.querySelectorAll('.card.selected').forEach(c => {
    c.classList.remove('selected');
    const btn = c.querySelector('.btn-add');
    if (btn) btn.textContent = '+ Pilih';
  });
  updateBar();
}

function chatOrder() {
  if (cart.size === 0) return;
  const items = [...cart.values()];
  const totalQty = items.reduce((s,i) => s+i.qty, 0);
  const totalIdr = items.reduce((s,i) => s+i.unitPrice*i.qty, 0);
  const totalFmt = 'Rp ' + totalIdr.toLocaleString('id-ID');
  const discount = document.getElementById('discountNote')?.value?.trim();

  let lines = [];
  lines.push('Halo Jastip-Q! 👋');
  lines.push('Saya mau order berikut:');
  lines.push('');
  items.forEach((item, i) => {
    lines.push((i+1) + '. ' + item.name + ' — ' + item.variant);
    lines.push('   Ukuran : ' + item.size);
    lines.push('   Qty    : ' + item.qty + ' pcs');
    lines.push('   Harga  : ' + item.priceFmt + '/pcs');
    lines.push('');
  });
  lines.push('─────────────────────');
  lines.push('Total item  : ' + totalQty + ' pcs');
  lines.push('Total harga : ' + totalFmt);
  lines.push('Ongkir      : Rp 50.000/item (tanpa box)');
  lines.push('DP (50%)    : Rp ' + Math.ceil(totalIdr * 0.5).toLocaleString('id-ID'));
  if (discount) {
    lines.push('');
    lines.push('📝 Request diskon: ' + discount);
  }
  lines.push('');
  lines.push('Mohon konfirmasi stok & info DP ya! 🙏');

  const msg = lines.join('\n');
  window.open('https://wa.me/6285692663335?text=' + encodeURIComponent(msg), '_blank');
}
